# Environment Variables for Backend Server

# Choose ONE backend mode:
# 1) MySQL mode (server/index.js)
# 2) MongoDB mode (server/index-mongo.js)

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=attendance_fines

# MongoDB Configuration (for server/index-mongo.js)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Server Configuration
PORT=3000

# IMPORTANT: Add this file to .gitignore to keep credentials secure
